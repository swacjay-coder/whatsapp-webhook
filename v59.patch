+function isBotPausedStatus(status = "") {
+  const value = compactText(status);
+
+  return value === "human reply" ||
+    value === "talk to team" ||
+    value === "bot paused" ||
+    value === "human mode" ||
+    value.includes("bot paused") ||
+    value.includes("human mode");
+}
+
+async function getSavedConversationStatusForPhone(phone, phoneNumberId = "") {
+  try {
+    const cleanPhone = (phone || "").toString().trim();
+    const cleanPhoneNumberId = normalizePhoneNumberId(phoneNumberId || "");
+
+    if (!cleanPhone) {
+      return "";
+    }
+
+    const loaded = await loadMessagesFromGoogleSheet();
+    const states = Array.isArray(loaded.conversationStates) ? loaded.conversationStates : [];
+
+    const exactState = states.find((state) =>
+      (state.phone || "").toString().trim() === cleanPhone &&
+      (!cleanPhoneNumberId || normalizePhoneNumberId(state.phoneNumberId || "") === cleanPhoneNumberId)
+    );
+
+    const fallbackState = exactState || states.find((state) =>
+      (state.phone || "").toString().trim() === cleanPhone
+    );
+
+    return (fallbackState?.conversation_status || "").toString().trim();
+  } catch (error) {
+    console.log("Saved conversation status lookup failed:");
+    console.log(error);
+    return "";
+  }
+}
+
+async function getBotPausedStatusForConversation(phone, phoneNumberId = "") {
+  const memoryStatus = conversationStatus[phone] || "";
+
+  if (isBotPausedStatus(memoryStatus)) {
+    return memoryStatus;
+  }
+
+  const savedStatus = await getSavedConversationStatusForPhone(phone, phoneNumberId);
+
+  if (isBotPausedStatus(savedStatus)) {
+    conversationStatus[phone] = savedStatus;
+    return savedStatus;
+  }
+
+  return "";
+}
